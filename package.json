{
  "name": "@ably/rpc",
  "version": "0.1.2",
  "description": "RPC over Ably Realtime — JSON-RPC 2.0 and Cap'n Web support",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/mjs/index.js",
  "types": "./dist/mjs/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/mjs/index.d.ts",
        "default": "./dist/mjs/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    },
    "./json-rpc": {
      "import": {
        "types": "./dist/mjs/json-rpc.d.ts",
        "default": "./dist/mjs/json-rpc.js"
      },
      "require": {
        "types": "./dist/cjs/json-rpc.d.ts",
        "default": "./dist/cjs/json-rpc.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run build:mjs && npm run build:cjs",
    "build:mjs": "tsc -p tsconfig.mjs.json",
    "build:cjs": "tsc -p tsconfig.cjs.json && echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ably-labs/ably-rpc.git"
  },
  "homepage": "https://github.com/ably-labs/ably-rpc#readme",
  "bugs": {
    "url": "https://github.com/ably-labs/ably-rpc/issues"
  },
  "keywords": [
    "ably",
    "rpc",
    "json-rpc",
    "capnweb",
    "realtime",
    "pubsub",
    "websocket",
    "transport"
  ],
  "dependencies": {
    "json-rpc-2.0": "^1.7.1"
  },
  "peerDependencies": {
    "ably": "^2.0.0"
  },
  "devDependencies": {
    "@vercel/node": "^3.0.0",
    "ably": "^2.0.0",
    "jsonwebtoken": "^9.0.3",
    "typescript": "^5.3.3",
    "vitest": "^3.0.0"
  },
  "workspaces": [
    "demo"
  ]
}
